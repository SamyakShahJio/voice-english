# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Anthropic (Claude) — Sarah's brain
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — speech-to-text (Scribe) + text-to-speech
ELEVENLABS_API_KEY=sk_...

# Which Claude model powers Sarah. Toggle for latency vs quality.
#   claude-sonnet-5              (smarter coaching, default)
#   claude-haiku-4-5-20251001   (fastest, lowest latency)
CLAUDE_MODEL=claude-sonnet-5

# ElevenLabs voice for Sarah (default: Monika Sogam — Hindi/English)
SARAH_VOICE_ID=Ms9OTvWb99V6DwRHZn6q

# ElevenLabs TTS model (multilingual required for Hindi + English)
TTS_MODEL=eleven_multilingual_v2

# Scribe STT model
STT_MODEL=scribe_v1

PORT=8795
