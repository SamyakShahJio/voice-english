# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Anthropic (Claude) — JBIQ's brain
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model powers JBIQ. Toggle for latency vs quality.
#   claude-sonnet-5             (smarter coaching — default)
#   claude-haiku-4-5-20251001   (fastest, lowest latency)
CLAUDE_MODEL=claude-sonnet-5

# Sarvam AI — the voice provider (TTS bulbul:v3 + STT saaras:v3).
SARVAM_API_KEY=sk_...
SARVAM_VOICE=ritu

# Which voice provider to use:
#   sarvam      (default — Sarvam only; ElevenLabs not needed)
#   auto        (ElevenLabs first, fall back to Sarvam on quota)
#   elevenlabs  (force ElevenLabs)
VOICE_PROVIDER=sarvam

# ElevenLabs — OPTIONAL, only needed if VOICE_PROVIDER=auto or elevenlabs.
# ELEVENLABS_API_KEY=sk_...
# JBIQ_VOICE_ID=Ms9OTvWb99V6DwRHZn6q
# TTS_MODEL=eleven_multilingual_v2
# STT_MODEL=scribe_v1

# Password gate for a deployed instance (HTTP Basic Auth). Leave BLANK for
# local dev (no prompt). Set it on your host to protect the public URL.
APP_PASSWORD=

PORT=8795
